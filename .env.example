DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/todo
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/todo_test

# Sekret do podpisywania tokenów JWT (HS256). USTAW własny przed wdrożeniem!
JWT_SECRET=change-me-to-a-long-random-string
# Czas życia tokenu w minutach (domyślnie 7 dni)
JWT_EXPIRE_MINUTES=10080

# Push (Expo) — opcjonalne
# EXPO_ACCESS_TOKEN=  # zalecany w produkcji; bez niego wysyłka też działa
# PUSH_TITLE=Todo     # tytuł powiadomienia push
