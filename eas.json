{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_USE_HTTP_SERVICES": "true",
        "EXPO_PUBLIC_API_URL": "https://eggjob.up.railway.app"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_USE_HTTP_SERVICES": "true",
        "EXPO_PUBLIC_API_URL": "https://eggjob.up.railway.app"
      }
    }
  }
}
