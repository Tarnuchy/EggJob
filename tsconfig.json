{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "react-native",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@/*": ["./src/frontend/*"]
    }
  },
  "include": ["App.tsx", "src/**/*.ts", "src/**/*.tsx", "babel.config.js"]
}
