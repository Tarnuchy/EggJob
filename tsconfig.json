{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"skipLibCheck": true,
		"types": ["vitest/globals"],
		"noEmit": true,
		"allowJs": false,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"baseUrl": "."
	},
	"include": [
		"tests/**/*.ts",
		"src/**/*.ts",
		"src/**/*.tsx",
		"vitest.config.ts"
	]
}
